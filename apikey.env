LLM_PROVIDER=ollama
# Modelo de chat local (descárgalo con: ollama pull llama3)
LLM_MODEL=llama3:latest
LLM_TEMPERATURE=0.2
LLM_TIMEOUT=60
LLM_MAX_TOKENS=1024

GOOGLE_API_KEY=
OLLAMA_EMBED_MODEL=nomic-embed-text
SOURCE_URL=https://lilianweng.github.io/posts/2023-06-23-agent/
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
TOP_K=4
LANGSMITH_TRACING=false
LANGSMITH_API_KEY=
LANGCHAIN_PROJECT=tdserag
